# Tempo MPP Configuration
# Copy to .env and fill in your values

# Agent wallet private keys (testnet)
TEMPO_SELLER_PRIVATE_KEY=0x...
TEMPO_BUYER_PRIVATE_KEY=0x...

# Settlement recipient (seller's address)
TEMPO_RECIPIENT=0x...

# Chain config
TEMPO_CHAIN_ID=42429
TEMPO_RPC_URL=https://rpc.testnet.tempo.xyz

# MPP mode: "live" for real chain, "mock" for demo without keys
MPP_MODE=mock
